{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 19
    },
    "configurePresets": [
        {
            "name": "dir",
            "hidden": true,
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "1"
            }
        },
        {
            "name": "debug",
            "description": "Recommended for inherits of Single-Config generator",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "description": "Recommended for inherits of Single-Config generator",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "ninja_multi",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
            }
        },
        {
            "name": "default",
            "inherits": [
                "dir",
                "ninja_multi"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "hidden": true,
            "description": "Recommended for inherits of Multi-Config generator",
            "configuration": "Debug"
        },
        {
            "name": "release",
            "hidden": true,
            "description": "Recommended for inherits of Multi-Config generator",
            "configuration": "Release"
        },
        {
            "name": "default_debug",
            "configurePreset": "default",
            "inherits": "debug"
        },
        {
            "name": "default_release",
            "configurePreset": "default",
            "inherits": "release"
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "hidden": true,
            "configuration": "Debug"
        },
        {
            "name": "release",
            "hidden": true,
            "configuration": "Release"
        },
        {
            "name": "default_debug",
            "configurePreset": "default",
            "inherits": "debug"
        },
        {
            "name": "default_release",
            "configurePreset": "default",
            "inherits": "release"
        }
    ],
    "packagePresets": [
        {
            "name": "debug",
            "hidden": true,
            "configurePreset": "default",
            "configurations": [
                "Debug"
            ]
        },
        {
            "name": "release",
            "hidden": true,
            "configurePreset": "default",
            "configurations": [
                "Release"
            ]
        },
        {
            "name": "default_debug",
            "inherits": [
                "debug"
            ],
            "generators": [
                "ZIP"
            ]
        },
        {
            "name": "default_release",
            "inherits": [
                "release"
            ],
            "generators": [
                "ZIP"
            ]
        }
    ],
    "workflowPresets": [
        {
            "name": "default",
            "steps": [
                {
                    "type": "configure",
                    "name": "default"
                },
                {
                    "type": "build",
                    "name": "default_release"
                },
                {
                    "type": "test",
                    "name": "default_release"
                },
                {
                    "type": "package",
                    "name": "default_release"
                }
            ]
        }
    ]
}